            <line
              x1="200"
              y1="210"
              x2="142"
              y2="185"
              stroke="#b380f0"
              stroke-width="1.2"
            />
            <line
              x1="142"
              y1="185"
              x2="118"
              y2="175"
              stroke="#b380f0"
              stroke-width="0.8"
              opacity="0.7"
            />
