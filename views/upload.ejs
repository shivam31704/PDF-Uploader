              y2="212"
              stroke="#7cacf8"
              stroke-width="0.8"
              opacity="0.7"
            />
            <circle cx="250" cy="222" r="4.5" fill="url(#dotGradR)" />
            <circle cx="275" cy="212" r="3.5" fill="url(#dotGradR)" />

            <line
              x1="200"
              y1="210"
              x2="258"
              y2="182"
              stroke="#7cacf8"
              stroke-width="1.2"
            />
            <line
              x1="258"
              y1="182"
              x2="282"
              y2="175"
              stroke="#7cacf8"
              stroke-width="0.8"
              opacity="0.7"
            />
            <circle cx="258" cy="182" r="4.5" fill="url(#dotGradR)" />
            <circle cx="282" cy="175" r="3.5" fill="url(#dotGradR)" />

            <line
