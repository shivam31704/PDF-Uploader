             C300,192 292,210 280,225 
             C268,240 250,252 238,268 
             C230,278 225,290 222,305 
             C220,315 215,325 210,330 Z"
              fill="none"
              stroke="url(#brainGrad)"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />

            <!-- Brainstem -->
            <path
              d="M190,330 C188,345 185,360 182,375"
              fill="none"
              stroke="#a855f7"
              stroke-width="2"
              stroke-linecap="round"
            />
            <path
              d="M210,330 C212,345 215,360 218,375"
              fill="none"
              stroke="#38bdf8"
              stroke-width="2"
              stroke-linecap="round"
            />

            <!-- Cerebellum -->
            <path
              d="M222,305 C240,298 255,280 265,258 C272,242 276,228 280,225"
              fill="none"
              stroke="#38bdf8"
              stroke-width="1.5"
              stroke-linecap="round"
            />

            <!-- Central trunk -->
            <line
              x1="200"
              y1="290"
              x2="200"
              y2="60"
              stroke="url(#brainGrad)"
              stroke-width="1.5"
              opacity="0.6"
