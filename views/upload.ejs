            <circle cx="215" cy="38" r="3" fill="url(#dotGradR)" />
          </g>
        </svg>
        <h1>DeepDocs</h1>
      </div>
    </header>
    <main>
      <div>
        <div>

          <form action="/upload" method="post" enctype="multipart/form-data">
            <!-- File Input -->
            <div class="mb-4">
              <p class="form-label fw-bold" id="text-line">UPLOAD PDF</p>

              <div class="upload-box text-center p-4">
                <input
                  type="file"
                  name="file"
                  id="fileInput"
                  accept="application/pdf"
                  required
                  hidden
                />

                <label for="fileInput" class="upload-label">
                  <div class="upload-icon">📄 <p class="upload-text">
                    Drag & Drop your PDF here <br />
                    <span>or click to browse</span>
                  </p></div>

                  

                  <p id="fileName" class="text-success small mt-2"></p>
                </label>
              </div>
            </div>

            <!-- Upload Button -->
            <button type="submit" class="btn btn-primary w-100">
              Upload File
            </button>
          </form>

          <!-- Divider -->
          <hr class="my-4" />

          <!-- Link to Files -->
          <div class="text-center">
            <a href="/f" class="text-decoration-none">
              View Uploaded Files📁
            </a>
          </div>
        </div>
      </div>

      <!-- ✅ Bootstrap JS (optional but good practice) -->
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </main>
    <footer>
      <p>© 2026 DeepDocs. All Rights Reserved.</p>

      <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms</a>
        <a href="#">Contact</a>
        <a href="#">About</a>
      </div>
    </footer>
  </body>
  <script>
    const fileInput = document.getElementById("fileInput");
    const fileName = document.getElementById("fileName");

    fileInput.addEventListener("change", function () {
      if (this.files.length > 0) {
        fileName.textContent = "Selected: " + this.files[0].name;
      }
    });
  </script>
</html>
