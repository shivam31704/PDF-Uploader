              y2="138"
              stroke="#b380f0"
              stroke-width="0.8"
              opacity="0.7"
            />
            <circle cx="138" cy="148" r="4.5" fill="url(#dotGradL)" />
            <circle cx="115" cy="138" r="3.5" fill="url(#dotGradL)" />

            <line
              x1="200"
              y1="130"
              x2="150"
              y2="105"
              stroke="#b380f0"
              stroke-width="1.2"
            />
            <circle cx="150" cy="105" r="4" fill="url(#dotGradL)" />

            <line
              x1="200"
              y1="95"
              x2="162"
              y2="68"
              stroke="#b380f0"
              stroke-width="1"
            />
            <circle cx="162" cy="68" r="3.5" fill="url(#dotGradL)" />

            <!-- Right branches + dots -->
            <line
              x1="200"
              y1="250"
              x2="250"
              y2="222"
              stroke="#7cacf8"
              stroke-width="1.2"
            />
            <line
